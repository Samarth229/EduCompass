generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model College {
  id            Int             @id @default(autoincrement())
  name          String
  city          String
  state         String
  type          String
  nirfRank      Int?
  nirfScore     Float?
  fees          Float
  rating        Float           @default(0)
  established   Int?
  description   String?
  website       String?
  image         String?
  field         String
  createdAt     DateTime        @default(now())
  courses       Course[]
  placements    Placement[]
  reviews       Review[]
  predictorData PredictorData[]
  savedBy       SavedCollege[]
}

model Course {
  id        Int     @id @default(autoincrement())
  collegeId Int
  name      String
  duration  Int
  seats     Int
  fees      Float
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model Placement {
  id               Int     @id @default(autoincrement())
  collegeId        Int
  year             Int
  avgPackage       Float
  highestPackage   Float
  placementPercent Float
  topRecruiters    String
  college          College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model Review {
  id        Int           @id @default(autoincrement())
  collegeId Int
  userId    String
  rating    Float
  comment   String
  createdAt DateTime      @default(now())
  college   College       @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     ReviewLike[]
  replies   ReviewReply[]
}

model ReviewLike {
  id       Int    @id @default(autoincrement())
  reviewId Int
  userId   String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}

model ReviewReply {
  id        Int      @id @default(autoincrement())
  reviewId  Int
  userId    String
  comment   String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PredictorData {
  id          Int     @id @default(autoincrement())
  collegeId   Int
  exam        String
  category    String
  openingRank Int
  closingRank Int
  year        Int
  college     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  savedColleges SavedCollege[]
  reviews       Review[]
  reviewLikes   ReviewLike[]
  reviewReplies ReviewReply[]
  accounts      Account[]
  sessions      Session[]
}

model SavedCollege {
  id        Int      @id @default(autoincrement())
  userId    String
  collegeId Int
  savedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
